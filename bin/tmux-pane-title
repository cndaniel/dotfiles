#!/bin/sh
# Window-tab label for tmux:
#   - Claude running on the pane  -> ✦ <project dir>
#   - a plain shell               ->  <current dir>
#   - anything else               -> <icon> <command>
# Usage: tmux-pane-title <pane_tty> <pane_current_command> <pane_current_path>

tty="${1#/dev/}"
cmd="$2"
path="$3"
dir="$(basename "$path")"

# Claude project takes priority, regardless of the foreground command.
if ps -t "$tty" -o args= 2>/dev/null | grep -q '[c]laude'; then
    printf '✦ %s' "$dir"
    exit 0
fi

case "$cmd" in
    nvim|vim|vi)                  printf ' %s' "$cmd" ;;
    node|npm|bun|pnpm|yarn|deno)  printf ' %s' "$cmd" ;;
    python*|ipython|uv|poetry)    printf ' %s' "$cmd" ;;
    git|lazygit|gh|tig)           printf ' %s' "$cmd" ;;
    docker|docker-compose)        printf ' %s' "$cmd" ;;
    ssh|mosh)                     printf ' %s' "$cmd" ;;
    zsh|bash|fish|sh|-zsh|-bash)  printf ' %s' "$dir" ;;
    *)                            printf '%s' "$cmd" ;;
esac
